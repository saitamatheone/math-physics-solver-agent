{
  "manifest_version": 3,
  "name": "Multi-Step Math & Physics Solver",
  "version": "1.0",
  "description": "Agentic AI that reasons through math and physics problems step by step using Gemini 3.1 Flash Lite.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Math & Physics Solver"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
